<%- include("partials/header") %>

<div class="container">
  <h1>Edit Post</h1>

  <form action="/edit/<%= post.id %>" method="POST">
    <input 
      type="text" 
      name="title" 
      value="<%= post.title %>" 
      required 
    />

    <textarea 
      name="content" 
      rows="6" 
      required
    ><%= post.content %></textarea>

    <button type="submit" class="btn">Update</button>
  </form>

  <br>
  <a href="/" class="btn">← Back</a>
</div>

<%- include("partials/footer") %>